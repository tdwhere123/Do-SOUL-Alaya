# Prohibit hoisting of vitest related packages to prevent environment pollution in Playwright workers
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=!@vitest/*
public-hoist-pattern[]=!vitest

hoist-pattern[]=*
hoist-pattern[]=!@vitest/*
hoist-pattern[]=!vitest
