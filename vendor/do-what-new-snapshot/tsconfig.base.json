{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmitOnError": true,
    "forceConsistentCasingInFileNames": true,
    "moduleDetection": "force",
    "paths": {
      "@do-what/protocol": ["./packages/protocol/src/index.ts"],
      "@do-what/core": ["./packages/core/src/index.ts"],
      "@do-what/soul": ["./packages/soul/src/index.ts"],
      "@do-what/engine-gateway": ["./packages/engine-gateway/src/index.ts"],
      "@do-what/storage": ["./packages/storage/src/index.ts"],
      "@do-what/ui-sdk": ["./packages/ui-sdk/src/index.ts"],
      "@do-what/surface-runtime": ["./packages/surface-runtime/src/index.ts"]
    },
    "types": ["node", "vitest/globals"]
  }
}
