{
  "name": "do-what",
  "private": true,
  "bin": {
    "do-what": "./bin/do-what.mjs"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "postinstall": "node ./scripts/link-root-bin.mjs",
    "dev": "node ./scripts/dev.mjs",
    "dev:desktop": "node ./scripts/dev.mjs --desktop",
    "doctor:host": "node ./scripts/check-host-prereqs.mjs",
    "build": "tsc -b packages/protocol packages/core packages/soul packages/engine-gateway packages/storage packages/ui-sdk packages/surface-runtime apps/app apps/core-daemon apps/tui",
    "test": "vitest run --config vitest.config.mjs",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.5"
  }
}
