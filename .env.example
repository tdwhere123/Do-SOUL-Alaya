# Do-SOUL Alaya — example environment configuration.
#
# Copy the relevant lines into your shell or into the daemon config env file
# (`~/.config/alaya/.env`, written by `alaya install`) and fill in real values.
# Every variable here is OPTIONAL unless marked "required"; Alaya runs with
# sane defaults when a variable is unset.
#
# NEVER commit real secrets. Use secret-refs (`env:NAME` / `file:/abs/path` /
# `keychain:service:account`) instead of inlining keys; the actual secret value
# lives only in the referenced location.

# ── Credentials & secret-refs ────────────────────────────────────────────────
# Secret-ref for the embedding / OpenAI-compatible key (scheme env:/file:/keychain:).
ALAYA_OPENAI_SECRET_REF=env:OPENAI_API_KEY
# Actual OpenAI API key, read when the secret-ref above resolves to env:OPENAI_API_KEY.
OPENAI_API_KEY=<your-openai-api-key>
# Secret-ref for the official Garden provider credential.
ALAYA_OFFICIAL_GARDEN_SECRET_REF=env:OPENAI_API_KEY
# Legacy alias for the Garden secret-ref (kept for back-compat; prefer the official one above).
ALAYA_GARDEN_OPENAI_SECRET_REF=env:OPENAI_API_KEY
# Garden provider kind selected at install time (e.g. official_api / openai).
ALAYA_GARDEN_PROVIDER_KIND=official_api
# Model id the official Garden uses.
OFFICIAL_GARDEN_MODEL=<your-garden-model>

# ── Embedding ────────────────────────────────────────────────────────────────
# Embedding backend: "local_onnx" runs the bundled ONNX model; anything else uses OpenAI-compatible.
ALAYA_EMBEDDING_PROVIDER=local_onnx
# Master switch for the embedding recall supplement ("true"/"false"); embedding never decides durable truth.
ALAYA_ENABLE_EMBEDDING_SUPPLEMENT=true
# OpenAI-compatible embedding model id (when not using local_onnx).
OPENAI_EMBEDDING_MODEL=<your-embedding-model>
# Base URL for the OpenAI-compatible embedding endpoint.
OPENAI_EMBEDDING_PROVIDER_URL=<your-embedding-provider-url>
# Local ONNX embedding model id (when ALAYA_EMBEDDING_PROVIDER=local_onnx).
ALAYA_LOCAL_EMBEDDING_MODEL=<your-local-embedding-model>
# Directory where the downloaded local embedding model is cached.
ALAYA_LOCAL_EMBEDDING_CACHE_DIR=<your-cache-dir>
# Hugging Face mirror endpoint used when fetching the local model.
HF_ENDPOINT=<your-hf-endpoint>

# ── Runtime / daemon ─────────────────────────────────────────────────────────
# Override the Alaya config directory (default: XDG config home / ~/.config/alaya).
ALAYA_CONFIG_DIR=<your-config-dir>
# HTTP port the core daemon listens on (default 3000).
PORT=3000
# Allowed CORS origin for the daemon (default http://localhost:5173).
ALLOWED_ORIGIN=http://localhost:5173
# Per-request auth token; a random token is generated when unset.
ALAYA_REQUEST_TOKEN=<your-request-token>
# Identity recorded for reviewer (governance) actions.
ALAYA_REVIEWER_IDENTITY=<your-reviewer-identity>
# Token authorizing reviewer (governance) actions.
ALAYA_REVIEWER_TOKEN=<your-reviewer-token>
# Set to "claude_code" to mark the principal runtime as Claude Code.
ALAYA_PRINCIPAL_RUNTIME=<your-principal-runtime>
# Default workspace id when an agent attaches without an explicit --workspace.
ALAYA_WORKSPACE_ID=<your-workspace-id>
# Comma-separated absolute repo roots Alaya is allowed to resolve workspaces under.
ALAYA_REPO_ROOTS=<your-repo-root-1>,<your-repo-root-2>
# Comma-separated allowlist of MCP server names the agent may attach.
ALAYA_ALLOWED_MCP_SERVERS=<server-1>,<server-2>
# Set to "1" to enable verbose CLI debug logging.
ALAYA_DEBUG=0

# ── Conflict-detection LLM ───────────────────────────────────────────────────
# Enable conflict detection ("true"/"false").
ALAYA_CONFLICT_DETECTION_ENABLED=false
# Enable the rule-based conflict pass ("true"/"false").
ALAYA_CONFLICT_RULE_ENABLED=false
# API key for the conflict-detection LLM.
ALAYA_CONFLICT_LLM_API_KEY=<your-conflict-llm-key>
# Conflict-detection LLM model (default gpt-5.4-mini).
ALAYA_CONFLICT_LLM_MODEL=gpt-5.4-mini
# Base URL for the conflict-detection LLM provider.
ALAYA_CONFLICT_LLM_PROVIDER_URL=<your-conflict-llm-url>
# Timeout in milliseconds for conflict-detection LLM calls.
ALAYA_CONFLICT_LLM_TIMEOUT_MS=<timeout-ms>

# ── Feature flags ────────────────────────────────────────────────────────────
# Enable ingest reconciliation ("true"/"false").
ALAYA_INGEST_RECONCILIATION_ENABLED=false
# Disable orphan detection by setting to "false" (enabled by default).
ORPHAN_DETECTION_ENABLED=true
# TTL in milliseconds for path-relationship co-usage counters.
ALAYA_PATHREL_COUNTER_TTL_MS=<ttl-ms>
# Co-usage count threshold before a path relationship is proposed.
ALAYA_PATHREL_CO_USAGE_THRESHOLD=<threshold>

# ── Benchmark harness (apps/bench-runner) ────────────────────────────────────
# Root directory for off-release bench artifacts.
ALAYA_BENCH_ARTIFACT_ROOT=<your-bench-artifact-root>
# Directory holding bench datasets.
ALAYA_BENCH_DATA_DIR=<your-bench-data-dir>
# Set to "1" to apply fast (less durable) SQLite pragmas during benches.
ALAYA_BENCH_FAST_PRAGMA=0
# SQLite temp_store override for bench runs (e.g. MEMORY).
ALAYA_BENCH_TEMP_STORE=<temp-store>
