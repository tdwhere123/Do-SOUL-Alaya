{
  "name": "@do-soul/alaya-bench-runner",
  "version": "0.3.5",
  "private": true,
  "description": "Daemon-attached bench runner that drives self-bench and LongMemEval-S evaluations against an in-process Alaya daemon. Owns the harness; eval package stays a zod-only leaf.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "alaya-bench-runner": "bin/alaya-bench-runner.mjs"
  },
  "files": ["dist/", "bin/"],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "pnpm exec vitest run --project @do-soul/alaya-bench-runner"
  },
  "dependencies": {
    "@do-soul/alaya": "workspace:*",
    "@do-soul/alaya-eval": "workspace:*",
    "@do-soul/alaya-protocol": "workspace:*",
    "@do-soul/alaya-storage": "workspace:*",
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "^3.24.2"
  }
}
