{
  "name": "@do-soul/alaya-inspector",
  "version": "0.3.11",
  "private": true,
  "description": "Memory Inspector loopback server for Do-SOUL Alaya — local-only memory tooling, NOT an agent surface.",
  "license": "MIT",
  "homepage": "https://github.com/tdwhere123/Do-SOUL-Alaya",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tdwhere123/Do-SOUL-Alaya.git",
    "directory": "apps/inspector"
  },
  "files": ["dist/", "web/dist/"],
  "type": "module",
  "main": "dist/runtime/server.js",
  "types": "dist/runtime/server.d.ts",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "tsc -b && pnpm --dir web build",
    "test": "pnpm exec vitest run --project @do-soul/alaya-inspector",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@do-soul/alaya-eval": "workspace:*",
    "@do-soul/alaya-protocol": "workspace:*",
    "@hono/node-server": "^1.13.8",
    "hono": "^4.6.10"
  }
}
