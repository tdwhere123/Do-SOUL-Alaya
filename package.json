{
  "name": "do-soul-alaya",
  "version": "0.3.11",
  "private": true,
  "description": "Do-SOUL Alaya — local-first memory core for CLI agents, ported from do-what-new",
  "engines": {
    "node": ">=20.19.0"
  },
  "bin": {
    "alaya": "./bin/alaya.mjs"
  },
  "scripts": {
    "build": "node ./scripts/build-existing.mjs",
    "test": "vitest run --config vitest.config.mjs",
    "typecheck": "pnpm --workspace-concurrency=1 --filter @do-soul/alaya-protocol --filter @do-soul/alaya-core --filter @do-soul/alaya-storage --filter @do-soul/alaya-engine-gateway --filter @do-soul/alaya-eval --filter @do-soul/alaya-inspector --filter @do-soul/alaya-bench-runner run typecheck",
    "hygiene:unused": "knip --config knip.json --no-progress --no-config-hints",
    "release:check-version": "node ./scripts/check-release-version.mjs",
    "fixtures:host-autonomy-witness": "node ./scripts/export-host-autonomy-witness.mjs",
    "alaya": "node ./bin/alaya.mjs",
    "doctor": "node ./bin/alaya.mjs doctor",
    "inspector": "node ./bin/alaya.mjs inspect --open"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "better-sqlite3": "12.9.0",
    "knip": "6.11.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.5"
  }
}
